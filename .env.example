# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# WhatsApp Business API (Meta)
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_APP_SECRET=

# Número real de WhatsApp en formato internacional, sin "+" ni espacios
# (ej: 5491126229494) — se usa para armar los links de wa.me de los QR.
WA_PHONE_NUMBER=

# Webhook de verificación (usado para validar la suscripción del webhook con Meta)
WEBHOOK_VERIFY_TOKEN=

# API key del dashboard comercial
DASHBOARD_API_KEY=

# Puerto del servidor (opcional, por defecto 3000)
PORT=3000
